{
  "name": "hardened",
  "version": "0.1.0",
  "description": "Deterministic CLI that finds unbounded TypeScript I/O and applies reviewable timeout fixes.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "hardened": "./dist/bin.js"
  },
  "files": ["dist", "README.md", "LICENSE"],
  "sideEffects": false,
  "keywords": [
    "hardened",
    "cli",
    "codemod",
    "resilience",
    "timeout",
    "retry",
    "production-readiness",
    "reliability",
    "static-analysis",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/compactbench/hardened.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/compactbench/hardened/issues"
  },
  "homepage": "https://github.com/compactbench/hardened#readme",
  "author": "hardened contributors",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node -e \"require('fs').chmodSync('./dist/bin.js', 0o755)\"",
    "typecheck": "tsc --noEmit",
    "start": "node dist/bin.js",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@hardened/core": "workspace:*",
    "@hardened/rules-risk": "workspace:*",
    "@octokit/rest": "^21.0.0",
    "commander": "^12.0.0",
    "picocolors": "^1.0.0",
    "simple-git": "^3.27.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "ts-morph": "^22.0.0",
    "typescript": "^5.4.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
