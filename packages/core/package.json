{
  "name": "@hardened/core",
  "version": "0.1.2",
  "description": "Rule engine, scanner, and fixer for hardened. AST-based engine that walks TypeScript source and applies deterministic code transformations.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "sideEffects": false,
  "keywords": [
    "hardened",
    "codemod",
    "ast",
    "typescript",
    "static-analysis",
    "resilience",
    "production-readiness",
    "linter",
    "ts-morph"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/compactbench/hardened.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/compactbench/hardened/issues"
  },
  "homepage": "https://github.com/compactbench/hardened/tree/main/packages/core#readme",
  "author": "hardened contributors",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "dev": "tsc -p tsconfig.json --watch",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "jiti": "^2.4.0",
    "micromatch": "^4.0.5",
    "ts-morph": "^22.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/micromatch": "^4.0.6",
    "@types/node": "^20.10.0",
    "typescript": "^5.4.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
