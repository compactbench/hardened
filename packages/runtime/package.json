{
  "name": "hardened-runtime",
  "version": "0.1.0",
  "description": "Runtime primitives for code transformed by hardened. Provides `resilient()` — a timeout/retry/circuit-breaker wrapper built on cockatiel.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "sideEffects": false,
  "keywords": [
    "hardened",
    "resilience",
    "timeout",
    "retry",
    "circuit-breaker",
    "cockatiel",
    "http-client"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/compactbench/hardened.git",
    "directory": "packages/runtime"
  },
  "bugs": {
    "url": "https://github.com/compactbench/hardened/issues"
  },
  "homepage": "https://github.com/compactbench/hardened/tree/main/packages/runtime#readme",
  "author": "hardened contributors",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "cockatiel": "^3.1.3"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.4.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
